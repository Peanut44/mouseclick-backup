{
  "version": 2,
  "rewrites": [
    {
      "source": "/:name.m3u8",
      "destination": "/api/hls?name=:name"
    },
    {
      "source": "/watch/:name.m3u8",
      "destination": "/api/hls?name=:name"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
